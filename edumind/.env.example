# ==================== 本地开发环境变量模板 ====================
# 复制此文件为 .env 后填入真实值
# cp .env.example .env
#
# .env 文件已加入 .gitignore，不会被提交到 Git

# 数据库密码
DB_PASS=change-me-to-a-strong-password

# 数据库用户（可选，默认为 postgres）
DB_USER=postgres

# JWT 密钥（openssl rand -base64 32）
JWT_SECRET=change-me-to-a-random-string-at-least-32-bytes

# OpenClaw AI Gateway API Key
OPENCLAW_API_KEY=change-me

# OneBot QQ Bot Token
ONEBOT_TOKEN=change-me

# MCP 服务间认证密钥
MCP_API_KEY=change-me

# Reranker ONNX 模型目录（可选，未安装模型时自动回退）
AI_MODEL_DIR=

# ==================== 文件存储 ====================
# local=本地磁盘（默认），s3=S3对象存储
STORAGE_TYPE=s3

# S3 对象存储（仅 STORAGE_TYPE=s3 时需要）
# 本地开发：MinIO（docker-compose 自带，endpoint=http://localhost:9000）
# 生产环境：阿里云 OSS S3 兼容端点（endpoint=https://oss-cn-hangzhou.aliyuncs.com）
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=homework-files
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_PATH_STYLE=true
